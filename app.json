{
  "expo": {
    "name": "LIQUID+",
    "slug": "liquid-plus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080c14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.liquidplus.invest"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080c14"
      },
      "package": "com.liquidplus.invest"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "liquidplus",
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "69556080-2357-48bc-b8e8-2ee73941a0ef"
      }
    },
    "owner": "liquidplus"
  }
}
